{
  "name": "@vue-cot/core",
  "type": "module",
  "version": "0.1.0",
  "description": "Vue 3 composables and parser for Cursor on Target (CoT) tactical messaging",
  "license": "MIT",
  "homepage": "https://github.com/belblue/vue-cot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/belblue/vue-cot.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/belblue/vue-cot/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "composables",
    "cursor-on-target",
    "cot",
    "tak",
    "atak",
    "wintak",
    "tak-server",
    "tactical",
    "situational-awareness",
    "geospatial",
    "websocket",
    "real-time",
    "xml-parser"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.3"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "tsup": "^8.5.1",
    "vitest": "^4.1.9",
    "vue": "^3.5.0"
  }
}
